@{
    ViewData["Title"] = "Bienvenido";
}

<div class="text-center mt-5">
    <h1 class="display-4">🌍 Bienvenido a TSI.NET 2026</h1>
    <p class="lead">
        Aplicación de gestión de <strong>Países, Confederaciones y Deportes</strong>
    </p>

    <hr />

    <div class="mt-4">
        <a class="btn btn-primary m-2" asp-controller="Pais" asp-action="Manage">
            Gestionar Países
        </a>

        <a class="btn btn-success m-2" asp-controller="Confederacion" asp-action="Manage">
            Gestionar Confederaciones
        </a>

        <a class="btn btn-warning m-2" asp-controller="Deporte" asp-action="Manage">
            Gestionar Deportes
        </a>
    </div>

    <div class="mt-5">
        <p class="text-muted">
            Proyecto desarrollado en ASP.NET Core MVC utilizando C#, Entity Framework y SQL Server.
        </p>
    </div>
</div>