<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NetMobile.Pages.ConfederacionFormPage"
             Title="Confederación">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label x:Name="TitleLabel" Text="Nueva confederación" Style="{StaticResource PageTitle}"/>
            <Label Text="Ingresá el nombre de la confederación" Style="{StaticResource PageSubtitle}"/>

            <VerticalStackLayout Spacing="6">
                <Label Text="Nombre" Style="{StaticResource FormLabel}"/>
                <Border Style="{StaticResource InputBorder}">
                    <Entry x:Name="NombreEntry" Placeholder="Nombre de la confederación"/>
                </Border>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,12,0,0">
                <Button Grid.Column="0" Text="Cancelar"
                        Style="{StaticResource SecondaryButton}"
                        Clicked="OnCancel"/>
                <Button Grid.Column="1" x:Name="SaveButton" Text="Guardar"
                        Style="{StaticResource PrimaryButton}"
                        Clicked="OnSave"/>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
